{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/reductor/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/reductor",
        "main": "libs/reductor/src/index.ts",
        "tsConfig": "libs/reductor/tsconfig.lib.json",
        "assets": ["libs/reductor/*.md"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/reductor/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/libs/reductor"],
      "options": {
        "jestConfig": "libs/reductor/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": []
}
